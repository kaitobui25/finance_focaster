# ===== LLM =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Database =====
DATABASE_URL=postgresql://forecaster:your_password@localhost:5432/finance_forecaster

# ===== Telegram (optional) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Scheduler =====
# Crawl interval in hours
CRAWL_INTERVAL_HOURS=2

# Report times in JST (HH:MM)
MORNING_REPORT_TIME=07:45
EVENING_REPORT_TIME=16:30

# ===== Timezone =====
TIMEZONE=Asia/Tokyo

# ===== Logging =====
LOG_LEVEL=INFO
